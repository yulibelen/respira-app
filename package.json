{
  "name": "respira-backend",
  "version": "1.0.0",
  "description": "API REST para RespiraApp - Estudio de Yoga Respira Profundo",
  "main": "server.js",
  "scripts": {
    "start":    "node server.js",
    "dev":      "nodemon server.js",
    "db:schema":"psql -U postgres -d respira_db -f ../db/schema.sql",
    "db:seed":  "node seed.js",
    "setup":    "npm install && npm run db:schema && npm run db:seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
